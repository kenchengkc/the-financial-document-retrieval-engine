# FDRE local environment template.
# Copy this file to `.env` for local development. Do not commit `.env`.

# App
APP_ENV=local
LOG_LEVEL=info
API_HOST=127.0.0.1
API_PORT=8000
CORS_ORIGINS=https://thefdre.com,https://www.thefdre.com,http://localhost:3000,http://127.0.0.1:3000

# Database
POSTGRES_DB=fdre
POSTGRES_USER=fdre
POSTGRES_PASSWORD=fdre
POSTGRES_HOST=localhost
POSTGRES_PORT=15432
POSTGRES_HOST_PORT=15432
DATABASE_URL=postgresql+psycopg://fdre:fdre@localhost:15432/fdre

# SEC EDGAR
# The SEC requires a descriptive user agent. Use your own contact value locally.
SEC_USER_AGENT="FDRE local development contact@example.com"
SEC_CACHE_DIR=data/cache/sec
SEC_RATE_LIMIT_REQUESTS_PER_SECOND=5

# Retrieval and indexing
EMBEDDING_PROVIDER=local_hash
EMBEDDING_MODEL=local-hash-v1
EMBEDDING_DIMENSIONS=
EMBEDDING_BATCH_SIZE=64
# Voyage free tier is ~3 RPM without billing; use 2 and batch size 128 in CI.
EMBEDDING_REQUESTS_PER_MINUTE=
SPARSE_PROVIDER=postgres
RERANKER_PROVIDER=none
RERANK_TOP_N=50

# Answer generation
ANSWER_GENERATOR=mock
ANSWER_TOP_K=8
MIN_EVIDENCE_CHUNKS=2
MIN_RETRIEVAL_SCORE=0.2

# Optional paid or external providers.
# Leave unset for the MVP and for tests.
OPENAI_API_KEY=
VOYAGE_API_KEY=
OPENSEARCH_URL=
